{
  "name": "@mnci/cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cli/src",
  "projectType": "application",
  "tags": ["type:publishable-lib"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build -w @mnci/cli"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test -w @mnci/cli"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint -w @mnci/cli"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm run test:e2e -w @mnci/cli"
      }
    }
  }
}
