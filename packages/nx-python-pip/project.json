{
  "name": "@mnci/nx-python-pip",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/nx-python-pip/src",
  "projectType": "library",
  "tags": ["type:publishable-lib"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build -w @mnci/nx-python-pip"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test -w @mnci/nx-python-pip"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint -w @mnci/nx-python-pip"
      }
    }
  }
}
