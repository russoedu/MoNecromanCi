{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "noEmit": false,
    "emitDeclarationOnly": false,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": false
  },
  "include": ["./src/**/*.ts"],
  "exclude": [
    "./coverage/**",
    "./dist/**",
    "./doc/**",
    "./node_modules/**",
    "./src/**/*.spec.ts"
  ]
}
