{
  "name": "monecromanci-v2",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/monecromanci-v2/src",
  "projectType": "application",
  "tags": ["type:internal-lib"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build -w monecromanci-v2"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test -w monecromanci-v2"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint -w monecromanci-v2"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm run test:e2e -w monecromanci-v2"
      }
    }
  }
}
