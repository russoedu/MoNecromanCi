{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "./dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2021",
    "lib": ["es2021"],
    "noEmit": true,
    "emitDeclarationOnly": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "exclude": [
    "./coverage/**",
    "./dist/**",
    "./doc/**",
    "./node_modules/**"
  ]
}
