{
  "name": "monecromanci-toolchain",
  "version": "0.1.0",
  "description": "Shared ESLint/TypeScript/Jest/TypeDoc configs and CI engine scripts for MoNecromanCI-managed monorepos.",
  "exports": {
    ".": "./package.json",
    "./package.json": "./package.json",
    "./eslint.config.mjs": "./eslint.config.mjs",
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./tsconfig.jest.json": "./tsconfig.jest.json",
    "./jest.preset.mjs": "./jest.preset.mjs",
    "./typedoc.json": "./typedoc.json",
    "./build-templates/*": "./build-templates/*",
    "./scripts/*": "./scripts/*"
  },
  "files": [
    "eslint.config.mjs",
    "tsconfig.base.json",
    "tsconfig.jest.json",
    "jest.preset.mjs",
    "jest.setup.mjs",
    "jest.clear.mjs",
    "typedoc.json",
    "build-templates",
    "scripts"
  ],
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "keywords": [
    "nx",
    "monorepo",
    "eslint",
    "tsconfig",
    "jest",
    "monecromanci"
  ],
  "author": "Eduardo Russo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/russoedu/MoNecromanCi.git",
    "directory": "libs/monecromanci-toolchain"
  },
  "homepage": "https://github.com/russoedu/MoNecromanCi/tree/main/libs/monecromanci-toolchain#readme",
  "bugs": {
    "url": "https://github.com/russoedu/MoNecromanCi/issues"
  },
  "dependencies": {
    "@eslint/markdown": "^8.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-jest": "^29.15.3",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-tsdoc-require-2": "^1.2.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-yml": "^3.5.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  }
}
