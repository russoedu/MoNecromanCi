{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2024",
    "lib": [
      "es2024"
    ],
    "noEmit": true,
    "emitDeclarationOnly": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "isolatedModules": true
  },
  "exclude": [
    "./coverage/**",
    "./dist/**",
    "./doc/**",
    "./node_modules/**"
  ]
}
