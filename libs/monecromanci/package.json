{
  "name": "monecromanci",
  "version": "0.8.5",
  "description": "MoNecromanCI — interactive CLI to summon, conjure, raise and validate NX monorepos (Azure DevOps & GitHub Actions): function/node apps, React/Vue/Svelte/Next.js apps, internal/publishable libs, CLI tools.",
  "bin": {
    "monecromanci": "./dist/cli.js",
    "mnci": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "tsup && node scripts/copyAssets.mjs",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "node e2e/dependencyInjection.e2e.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "start": "node dist/cli.js",
    "doc": "typedoc --tsconfig tsconfig.lib.json"
  },
  "keywords": [
    "nx",
    "monorepo",
    "azure-devops",
    "cli",
    "scaffold",
    "typescript"
  ],
  "author": "Eduardo Russo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/russoedu/MoNecromanCi.git",
    "directory": "libs/monecromanci"
  },
  "homepage": "https://github.com/russoedu/MoNecromanCi/tree/main/libs/monecromanci#readme",
  "bugs": {
    "url": "https://github.com/russoedu/MoNecromanCi/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@eslint/markdown": "^8.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-jest": "^29.15.3",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-tsdoc-require-2": "^1.2.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-yml": "^3.5.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
