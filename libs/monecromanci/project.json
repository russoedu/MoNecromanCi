{
  "name": "monecromanci",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/monecromanci/src",
  "projectType": "application",
  "tags": [
    "type:publishable-lib"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run build -w monecromanci"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test -w monecromanci"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint -w monecromanci"
      }
    },
    "doc": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run doc -w monecromanci"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}"
      }
    }
  }
}
