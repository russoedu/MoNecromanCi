{
  "name": "nx-magic",
  "version": "0.0.0",
  "description": "Interactive CLI to create and fix NX monorepos for Azure DevOps (function apps, React apps, internal/publishable libs, CLI tools).",
  "bin": {
    "nx-magic": "./dist/cli.js",
    "nxm": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "scripts": {
    "build": "tsup && node scripts/copyAssets.mjs",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "nx",
    "monorepo",
    "azure-devops",
    "cli",
    "scaffold",
    "typescript"
  ],
  "author": "Eduardo Russo",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@eslint/markdown": "^8.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-jest": "^29.15.3",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-tsdoc-require-2": "^1.2.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-yml": "^3.5.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
